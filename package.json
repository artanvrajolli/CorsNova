{
  "name": "corsnova",
  "version": "1.0.0",
  "description": "A lightweight and efficient CORS proxy server for development and testing.",
  "main": "app.js",
  "type": "module",
  "scripts": {
    "start": "node app.js",
    "test": "node --test --test-reporter=spec --test-concurrency=1 --test-force-exit \"test/**/*.test.js\"",
    "test:coverage": "c8 --reporter=text --reporter=lcov node --test --test-concurrency=1 --test-force-exit \"test/**/*.test.js\"",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/artanvrajolli/CorsNova.git"
  },
  "keywords": [
    "cors",
    "proxy",
    "vercel",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/artanvrajolli/CorsNova/issues"
  },
  "homepage": "https://github.com/artanvrajolli/CorsNova#readme",
  "engines": {
    "node": "22.x",
    "npm": "10.x"
  },
  "dependencies": {
    "express": "4.21.2",
    "multer": "1.4.5-lts.1"
  },
  "devDependencies": {
    "@eslint/js": "9.20.0",
    "c8": "10.1.3",
    "eslint": "9.20.1",
    "globals": "15.15.0",
    "nock": "14.0.0",
    "supertest": "7.2.2"
  }
}
